# include <iostream>
using namespace std;

class Node {
    public:
    int data;
    Node* next;
    Node(int val) {
        data = val;
        next = NULL;
    }
};

class Queue {
    private:
    Node* front;
    Node* rear;
    public:
    Queue() {
        front = rear = NULL;
    }
    void enqueue(int val) {
        Node* newNode = new Node(val);
        if(!rear) {
            front = rear = newNode;
            return;
        }
        rear->next = newNode;
        rear = newNode;
    }
    void dequeue() {
        if(!front) return;
        Node* temp = front;
        front = front->next;
        if(!front) rear = NULL;
        delete temp;
    }
    int getFront() {
        if(front) return front->data;
        return -1;
    }
    bool isEmpty() {
        return front == NULL;
    }
};

int main() {
    Queue q;
    q.enqueue(10);
    q.enqueue(20);
    cout << q.getFront() << "\n";
    q.dequeue();
    cout << q.getFront() << "\n";
    return 0;
}