#include <iostream>

struct Node {
    int data;
    Node* next;
    Node(int val) : data(val), next(nullptr) {}
};

class Stack {
private:
    Node* top;
    int size;

public:
    Stack() : top(nullptr), size(0) {}

    void push(int val) {
        Node* newNode = new Node(val);
        newNode->next = top;
        top = newNode;
        size++;
    }

    void pop() {
        if (isEmpty()) {
            std::cout << "Stack Underflow" << std::endl;
            return;
        }
        Node* temp = top;
        top = top->next;
        delete temp;
        size--;
    }

    int peek() {
        if (isEmpty()) return -1;
        return top->data;
    }

    bool isEmpty() {
        return top == nullptr;
    }

    int getSize() {
        return size;
    }

    void display() {
        if (isEmpty()) return;
        Node* temp = top;
        while (temp) {
            std::cout << temp->data << " -> ";
            temp = temp->next;
        }
        std::cout << "NULL" << std::endl;
    }

    void clear() {
        while (!isEmpty()) {
            pop();
        }
    }

    ~Stack() {
        clear();
    }
};

int main() {
    Stack s;
    s.push(10);
    s.push(20);
    s.push(30);
    
    std::cout << "Stack elements: ";
    s.display();
    
    std::cout << "Size: " << s.getSize() << std::endl;
    std::cout << "Top: " << s.peek() << std::endl;
    
    s.pop();
    std::cout << "After pop: ";
    s.display();
    
    std::cout << "Is Empty: " << (s.isEmpty() ? "Yes" : "No") << std::endl;
    
    s.clear();
    std::cout << "After clear, Is Empty: " << (s.isEmpty() ? "Yes" : "No") << std::endl;

    return 0;
}
