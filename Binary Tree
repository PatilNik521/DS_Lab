#include <iostream>
#include <queue>

struct Node {
    int data;
    Node *left, *right;
    Node(int val) : data(val), left(nullptr), right(nullptr) {}
};

class BinaryTree {
    Node* root;

    Node* insert(Node* node, int val) {
        if (!node) return new Node(val);
        if (!node->left) node->left = new Node(val);
        else if (!node->right) node->right = new Node(val);
        else {
            if (rand() % 2) node->left = insert(node->left, val);
            else node->right = insert(node->right, val);
        }
        return node;
    }

    void inorder(Node* node) {
        if (!node) return;
        inorder(node->left);
        std::cout << node->data << " ";
        inorder(node->right);
    }

    void preorder(Node* node) {
        if (!node) return;
        std::cout << node->data << " ";
        preorder(node->left);
        preorder(node->right);
    }

    void postorder(Node* node) {
        if (!node) return;
        postorder(node->left);
        postorder(node->right);
        std::cout << node->data << " ";
    }

    void levelorder(Node* node) {
        if (!node) return;
        std::queue<Node*> q;
        q.push(node);
        while (!q.empty()) {
            Node* curr = q.front();
            q.pop();
            std::cout << curr->data << " ";
            if (curr->left) q.push(curr->left);
            if (curr->right) q.push(curr->right);
        }
    }

    int height(Node* node) {
        if (!node) return 0;
        return 1 + std::max(height(node->left), height(node->right));
    }

    int countNodes(Node* node) {
        if (!node) return 0;
        return 1 + countNodes(node->left) + countNodes(node->right);
    }

public:
    BinaryTree() : root(nullptr) {}
    void insert(int val) { root = insert(root, val); }
    void displayInorder() { inorder(root); std::cout << std::endl; }
    void displayPreorder() { preorder(root); std::cout << std::endl; }
    void displayPostorder() { postorder(root); std::cout << std::endl; }
    void displayLevelorder() { levelorder(root); std::cout << std::endl; }
    int getHeight() { return height(root); }
    int getTotalNodes() { return countNodes(root); }
};

int main() {
    BinaryTree tree;
    tree.insert(1);
    tree.insert(2);
    tree.insert(3);
    tree.insert(4);
    tree.insert(5);
    tree.insert(6);
    tree.insert(7);

    std::cout << "Inorder: "; tree.displayInorder();
    std::cout << "Preorder: "; tree.displayPreorder();
    std::cout << "Postorder: "; tree.displayPostorder();
    std::cout << "Level Order: "; tree.displayLevelorder();
    std::cout << "Height: " << tree.getHeight() << std::endl;
    std::cout << "Total Nodes: " << tree.getTotalNodes() << std::endl;

    return 0;
}
